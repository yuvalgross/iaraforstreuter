{
  "name": "iara-forstreuter",
  "version": 2,
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": "./",
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "env": [],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/.*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400"
        }
      ]
    }
  ]
}
